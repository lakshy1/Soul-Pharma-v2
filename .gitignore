# Root level gitignore for Soul Pharma project

# Dependencies
node_modules/
*/node_modules/

# Environment variables (NEVER commit these)
.env
.env.local
.env.*.local
Backend/.env
Frontend/.env

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Lock files (optional: keep or remove based on preference)
# package-lock.json
# yarn.lock

# Temporary/Build
tmp/
temp/
dist/

# Testing
coverage/
.nyc_output/

# Netlify
.netlify/

# Misc
*.bak
*.orig
